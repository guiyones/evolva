<div class="list-page">
  <div class="list-page-header">
    <h1 class="list-page-title">Desafios</h1>
    <%= link_to "+ Novo", new_challenge_path, class: "list-action-new" %>
  </div>

  <% if @challenges.empty? %>
    <div class="list-empty">
      <p>Nenhum desafio ainda.</p>
      <%= link_to "Criar seu primeiro desafio →", new_challenge_path %>
    </div>
  <% else %>
    <div class="list-items">
      <%= render partial: "list_item", collection: @challenges, as: :challenge %>
    </div>
  <% end %>
</div>
