<div class="form-page">
  <div class="form-page-inner">
    <h1 class="form-page-title">Editar Desafio</h1>
    <p class="form-page-subtitle">Você pode editar o título e a descrição.</p>

    <%= form_with model: @challenge do |f| %>
      <%= render "shared/form_errors", record: @challenge %>

      <div class="form-section">
        <%= f.label :title, "Qual é o desafio?", class: "form-label" %>
        <%= f.text_field :title, class: "form-input on-card" %>
      </div>

      <div class="form-section">
        <%= f.label :description, "Por que você está fazendo isso?", class: "form-label" %>
        <%= f.text_area :description, class: "form-input form-textarea on-card", rows: 3 %>
      </div>

      <%= f.submit "Salvar alterações", class: "form-submit" %>
    <% end %>

    <%= link_to "← Voltar", challenge_path(@challenge), class: "form-back-link" %>
  </div>
</div>
