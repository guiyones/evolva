<div class="checkin-page">
  <div class="checkin-page-inner">
    <div class="checkin-header">
      <p class="checkin-challenge-title"><%= @challenge.title %></p>
      <h1 class="checkin-day">Dia <%= @challenge.current_day %> de <%= @challenge.duration_days %></h1>
    </div>

    <%= form_with model: [ @challenge, @checkin ], class: "checkin-form" do |f| %>
      <div style="text-align: center;">
        <p class="checkin-prompt">Você fez hoje?</p>
        <button type="submit" class="checkin-yes-btn">Sim, fiz!</button>
      </div>

      <div>
        <p class="checkin-prompt">Como foi? <span style="color: #4b5563;">(opcional)</span></p>
        <input type="hidden" name="checkin[feeling]" id="checkin_feeling" value="">
        <div class="checkin-feelings" data-controller="feeling">
          <% CheckinsHelper::FEELING_LABELS.each do |value, label| %>
            <button type="button"
                    data-feeling-target="option"
                    data-action="click->feeling#select"
                    data-value="<%= value %>"
                    class="checkin-feeling-btn"><%= label %></button>
          <% end %>
        </div>
      </div>

      <div>
        <p class="checkin-prompt">Alguma nota? <span style="color: #4b5563;">(opcional)</span></p>
        <%= f.text_area :note, class: "checkin-note", rows: 3, placeholder: "Hoje foi difícil mas fiz..." %>
      </div>
    <% end %>

    <%= link_to "← Voltar", challenge_path(@challenge), class: "form-back-link" %>
  </div>
</div>
