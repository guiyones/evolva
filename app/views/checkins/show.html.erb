<div class="checkin-show">
  <%= link_to "← Voltar", challenge_path(@challenge), class: "reward-back" %>

  <div class="checkin-show-card">
    <div class="checkin-show-header">
      <h1 class="checkin-show-title">Dia <%= @checkin.day_number %> de <%= @challenge.duration_days %></h1>
      <span class="checkin-show-date"><%= @checkin.created_at.strftime("%d/%m/%Y") %></span>
    </div>

    <div class="checkin-row">
      <span class="checkin-row-label">Status</span>
      <span class="checkin-row-value success">✓ Feito</span>
    </div>

    <% if @checkin.feeling.present? %>
      <div class="checkin-row">
        <span class="checkin-row-label">Como foi</span>
        <span class="checkin-row-value-pill"><%= feeling_label(@checkin.feeling) %></span>
      </div>
    <% end %>

    <% if @checkin.note.present? %>
      <div class="checkin-note-block">
        <p class="checkin-note-label">Nota</p>
        <p class="checkin-note-text"><%= @checkin.note %></p>
      </div>
    <% end %>

    <% if @checkin.feeling.blank? && @checkin.note.blank? %>
      <p class="checkin-empty">Nenhuma informação adicional registrada.</p>
    <% end %>
  </div>
</div>
