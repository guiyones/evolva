<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md px-8 py-10 rounded-2xl" style="background: #1F2937;">

    <h1 class="text-2xl font-bold text-white mb-2">Entrar</h1>
    <p class="text-gray-400 mb-8">Continue sua evolução</p>

    <% if alert = flash[:alert] %>
      <div class="rounded-lg px-4 py-3 mb-6 text-sm" style="background: rgba(239,68,68,0.1); color: #f87171;">
        <p><%= alert %></p>
      </div>
    <% end %>

    <% if notice = flash[:notice] %>
      <div class="rounded-lg px-4 py-3 mb-6 text-sm" style="background: rgba(34,197,94,0.1); color: #22C55E;">
        <p><%= notice %></p>
      </div>
    <% end %>

    <%= form_with url: session_url, class: "space-y-5" do |form| %>

      <div>
        <%= form.label :email_address, "Email", class: "block text-sm text-gray-400 mb-2" %>
        <%= form.email_field :email_address,
            required: true, autofocus: true, autocomplete: "username",
            class: "w-full rounded-lg px-4 py-3 text-white",
            style: "background: #111827; border: 0.5px solid #374151;",
            placeholder: "seu@email.com",
            value: params[:email_address] %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "block text-sm text-gray-400 mb-2" %>
        <%= form.password_field :password,
            required: true, autocomplete: "current-password", maxlength: 72,
            class: "w-full rounded-lg px-4 py-3 text-white",
            style: "background: #111827; border: 0.5px solid #374151;",
            placeholder: "sua senha" %>
      </div>

      <%= form.submit "Entrar",
          class: "w-full text-white font-semibold py-3 rounded-lg cursor-pointer transition-colors bg-[#6C4DFF] hover:bg-[#5A3DE6]" %>

    <% end %>

    <p class="text-center text-gray-500 text-sm mt-6">
      Não tem conta?
      <%= link_to "Criar conta", new_registration_path, style: "color: #6C4DFF;" %>
    </p>
  </div>
</div>
