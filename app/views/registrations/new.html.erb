<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md px-8 py-10 rounded-2xl" style="background: #1F2937;">

    <h1 class="text-2xl font-bold text-white mb-2">Criar conta</h1>
    <p class="text-gray-400 mb-8">Comece sua evolução hoje</p>

    <%= form_with model: @user, url: registration_path do |f| %>

      <% if @user.errors.any? %>
        <div class="rounded-lg px-4 py-3 mb-6 text-sm" style="background: rgba(239,68,68,0.1); color: #f87171;">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="mb-5">
        <%= f.label :name, "Como você quer ser chamado?", class: "block text-sm text-gray-400 mb-2" %>
        <%= f.text_field :name,
            class: "w-full rounded-lg px-4 py-3 text-white",
            style: "background: #111827; border: 0.5px solid #374151;",
            placeholder: "ex: Gui" %>
      </div>

      <div class="mb-5">
        <%= f.label :email_address, "Email", class: "block text-sm text-gray-400 mb-2" %>
        <%= f.email_field :email_address,
            class: "w-full rounded-lg px-4 py-3 text-white",
            style: "background: #111827; border: 0.5px solid #374151;",
            placeholder: "seu@email.com" %>
      </div>

      <div class="mb-5">
        <%= f.label :password, "Senha", class: "block text-sm text-gray-400 mb-2" %>
        <%= f.password_field :password,
            class: "w-full rounded-lg px-4 py-3 text-white",
            style: "background: #111827; border: 0.5px solid #374151;",
            placeholder: "mínimo 12 caracteres" %>
      </div>

      <div class="mb-8">
        <%= f.label :password_confirmation, "Confirmar senha", class: "block text-sm text-gray-400 mb-2" %>
        <%= f.password_field :password_confirmation,
            class: "w-full rounded-lg px-4 py-3 text-white",
            style: "background: #111827; border: 0.5px solid #374151;",
            placeholder: "repita a senha" %>
      </div>

      <%= f.submit "Criar conta",
          class: "w-full text-white font-semibold py-3 rounded-lg cursor-pointer transition-colors",
          style: "background: #6C4DFF;" %>

    <% end %>

    <p class="text-center text-gray-500 text-sm mt-6">
      Já tem conta?
      <%= link_to "Entrar", new_session_path, style: "color: #6C4DFF;" %>
    </p>
  </div>
</div>

