<div class="auth-screen">
  <div class="auth-card">
    <h1 class="auth-title">Criar conta</h1>
    <p class="auth-subtitle">Comece sua evolução hoje</p>

    <%= form_with model: @user, url: registration_path do |f| %>
      <%= render "shared/form_errors", record: @user %>

      <div class="form-section">
        <%= f.label :name, "Como você quer ser chamado?", class: "form-label" %>
        <%= f.text_field :name, class: "form-input", placeholder: "ex: Gui" %>
      </div>

      <div class="form-section">
        <%= f.label :email_address, "Email", class: "form-label" %>
        <%= f.email_field :email_address, class: "form-input", placeholder: "seu@email.com" %>
      </div>

      <div class="form-section">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, class: "form-input", placeholder: "mínimo 12 caracteres" %>
      </div>

      <div class="form-section">
        <%= f.label :password_confirmation, "Confirmar senha", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-input", placeholder: "repita a senha" %>
      </div>

      <%= f.submit "Criar conta", class: "form-submit" %>
    <% end %>

    <p class="auth-footer">
      Já tem conta? <%= link_to "Entrar", new_session_path %>
    </p>
    <p class="auth-footer">
      <%= link_to "Como funciona?", how_it_works_path %>
    </p>
  </div>
</div>
