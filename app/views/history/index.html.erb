<div class="list-page">
  <h1 class="list-page-title" style="margin-bottom: 2rem;">Histórico</h1>

  <% if @completed_quests.any? %>
    <div class="history-section">
      <h2 class="history-section-title">Jornadas concluídas</h2>
      <div class="list-items">
        <%= render partial: "completed_quest", collection: @completed_quests, as: :quest %>
      </div>
    </div>
  <% end %>

  <% if @completed_challenges.any? %>
    <div class="history-section">
      <h2 class="history-section-title">Desafios concluídos</h2>
      <div class="list-items">
        <%= render partial: "completed_challenge", collection: @completed_challenges, as: :challenge %>
      </div>
    </div>
  <% end %>

  <% if @finished_challenges.any? %>
    <div class="history-section">
      <h2 class="history-section-title">Encerrados</h2>
      <div class="list-items">
        <%= render partial: "finished_challenge", collection: @finished_challenges, as: :challenge %>
      </div>
    </div>
  <% end %>

  <% if @completed_challenges.empty? && @finished_challenges.empty? && @completed_quests.empty? %>
    <div class="list-empty">
      <p>Nenhum desafio concluído ainda.</p>
      <p style="font-size: 14px; color: #4b5563;">Complete seu primeiro desafio para ver o histórico.</p>
    </div>
  <% end %>
</div>
