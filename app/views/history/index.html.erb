<div class="max-w-lg mx-auto px-4 py-10">

  <h1 class="text-2xl font-bold text-white mb-8">Histórico</h1>

  <% if @completed_quests.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Jornadas concluídas</h2>
      <div class="space-y-3">
        <% @completed_quests.each do |quest| %>
          <%= link_to quest_path(quest), class: "block rounded-xl p-4 transition-colors", style: "background: #1F2937;" do %>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold" style="color: #22C55E;">✓ <%= quest.title %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= quest.total %> desafios · <%= quest.completed_at.strftime("%d/%m/%Y") %>
                </p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @completed_challenges.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Desafios concluídos</h2>
      <div class="space-y-3">
        <% @completed_challenges.each do |challenge| %>
          <%= link_to challenge_path(challenge), class: "block rounded-xl p-4 transition-colors", style: "background: #1F2937;" do %>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold" style="color: #22C55E;">✓ <%= challenge.title %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= challenge.duration_days %> de <%= challenge.duration_days %> dias
                  · <%= challenge.completed_at.strftime("%d/%m/%Y") %>
                </p>
              </div>
              <% if challenge.reward&.redeemed? %>
                <span class="text-xs text-gray-500">🎁 resgatado</span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @finished_challenges.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Recomeçados</h2>
      <div class="space-y-3">
        <% @finished_challenges.each do |challenge| %>
          <%= link_to challenge_path(challenge), class: "block rounded-xl p-4 transition-colors opacity-70", style: "background: #1F2937;" do %>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold text-gray-400">↩ <%= challenge.title %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= challenge.progress %> de <%= challenge.duration_days %> dias
                  · <%= challenge.completed_at&.strftime("%d/%m/%Y") %>
                </p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @completed_challenges.empty? && @finished_challenges.empty? && @completed_quests.empty? %>
    <div class="text-center py-20">
      <p class="text-gray-500">Nenhum desafio concluído ainda.</p>
      <p class="text-gray-600 text-sm mt-2">Complete seu primeiro desafio para ver o histórico.</p>
    </div>
  <% end %>
</div>

