<div class="max-w-lg mx-auto px-4 py-10">

  <h1 class="text-2xl font-bold text-white mb-8">Histórico</h1>

  <%# Quests concluídas %>
  <% if @completed_quests.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
        Quests concluídas
      </h2>
      <div class="space-y-3">
        <% @completed_quests.each do |quest| %>
          <%= link_to quest_path(quest),
              class: "block bg-gray-900 rounded-xl p-4 hover:bg-gray-800 transition-colors" do %>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-green-400 text-sm font-semibold">✓ <%= quest.title %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= quest.total %> challenges concluídos
                  · <%= quest.completed_at.strftime("%d/%m/%Y") %>
                </p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Challenges concluídos %>
  <% if @completed_challenges.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
        Challenges concluídos
      </h2>
      <div class="space-y-3">
        <% @completed_challenges.each do |challenge| %>
          <%= link_to challenge_path(challenge),
              class: "block bg-gray-900 rounded-xl p-4 hover:bg-gray-800 transition-colors" do %>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-green-400 text-sm font-semibold">✓ <%= challenge.title %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= challenge.duration_days %> de <%= challenge.duration_days %> dias
                  · <%= challenge.completed_at.strftime("%d/%m/%Y") %>
                </p>
              </div>
              <% if challenge.reward&.redeemed? %>
                <span class="text-xs text-gray-500">🎁 resgatado</span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Challenges recomeçados %>
  <% if @finished_challenges.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
        Recomeçados
      </h2>
      <div class="space-y-3">
        <% @finished_challenges.each do |challenge| %>
          <%= link_to challenge_path(challenge),
              class: "block bg-gray-900/50 rounded-xl p-4 hover:bg-gray-800 transition-colors" do %>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-semibold">↩ <%= challenge.title %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= challenge.progress %> de <%= challenge.duration_days %> dias
                  · <%= challenge.completed_at&.strftime("%d/%m/%Y") %>
                </p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Estado vazio %>
  <% if @completed_challenges.empty? && @finished_challenges.empty? && @completed_quests.empty? %>
    <div class="text-center py-20">
      <p class="text-gray-500">Nenhum desafio concluído ainda.</p>
      <p class="text-gray-600 text-sm mt-2">Complete seu primeiro challenge para ver o histórico.</p>
    </div>
  <% end %>

</div>

