<div class="quest-show">
  <%= render "header", quest: @quest %>

  <h1 class="quest-title-h1"><%= @quest.title %></h1>
  <% if @quest.description.present? %>
    <p class="quest-description"><%= @quest.description %></p>
  <% end %>

  <%= render "progress", quest: @quest %>

  <div class="quest-challenges-block">
    <p class="quest-challenges-label">Desafios</p>

    <% if @quest.challenges.empty? %>
      <p style="color: #4b5563; font-size: 14px;">Nenhum desafio ainda.</p>
    <% else %>
      <div class="quest-challenges-list">
        <% @quest.challenges.order(created_at: :asc).each do |challenge| %>
          <%= render "challenge_row", challenge: challenge %>
        <% end %>
      </div>
    <% end %>

    <% if @quest.can_add_challenge? %>
      <%= render "attach_challenge", quest: @quest %>
    <% end %>
  </div>

  <% if @quest.reward.present? %>
    <%= render "reward_block", reward: @quest.reward %>
  <% end %>

  <%= link_to "← Voltar", quests_path, class: "quest-back-link" %>
</div>
