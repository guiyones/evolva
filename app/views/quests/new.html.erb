<div class="form-page">
  <div class="form-page-inner">
    <h1 class="form-page-title">Nova Jornada</h1>
    <p class="form-page-subtitle">Defina sua jornada de longo prazo</p>

    <%= form_with model: @quest do |f| %>
      <%= render "shared/form_errors", record: @quest %>

      <div class="form-section">
        <%= f.label :title, "Qual é a jornada?", class: "form-label" %>
        <%= f.text_field :title, class: "form-input on-card", placeholder: "ex: Criar hábito de leitura" %>
      </div>

      <div class="form-section">
        <%= f.label :description, "Por que essa jornada importa?", class: "form-label" %>
        <%= f.text_area :description, class: "form-input form-textarea on-card", rows: 3, placeholder: "opcional" %>
      </div>

      <div class="form-section">
        <%= f.label :reward, "Qual será sua recompensa final?", class: "form-label" %>
        <%= f.fields_for :reward do |r| %>
          <%= r.text_field :description, class: "form-input on-card", placeholder: "ex: uma estante nova" %>
        <% end %>
        <p style="font-size: 12px; color: #4b5563; margin-top: 0.5rem;">opcional</p>
      </div>

      <%= f.submit "Criar jornada", class: "form-submit" %>
    <% end %>

    <%= link_to "← Voltar", quests_path, class: "form-back-link" %>
  </div>
</div>
