<div class="list-page">
  <div class="list-page-header">
    <h1 class="list-page-title">Jornadas</h1>
    <%= link_to "+ Nova", new_quest_path, class: "list-action-new" %>
  </div>

  <% if @quests.empty? %>
    <div class="list-empty">
      <p>Nenhuma jornada ainda.</p>
      <%= link_to "Criar sua primeira jornada →", new_quest_path %>
    </div>
  <% else %>
    <div class="list-items">
      <%= render partial: "list_item", collection: @quests, as: :quest %>
    </div>
  <% end %>
</div>
