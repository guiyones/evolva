<% source = reward.challenge || reward.quest %>
<%= link_to reward_path(reward), class: "reward-card #{reward.status}" do %>
  <div class="reward-row">
    <div class="reward-icon <%= reward.status %>"><%= reward.unlocked? ? "🎁" : "🔒" %></div>
    <div class="reward-info">
      <p class="reward-title <%= 'locked' if reward.locked? %>"><%= reward.description %></p>
      <p class="reward-source"><%= source&.title %></p>
    </div>
  </div>

  <% if reward.unlocked? %>
    <div class="reward-divider"></div>
    <span class="reward-status">Pronto para resgatar</span>
  <% elsif source %>
    <div class="reward-progress-row">
      <span>Progresso</span>
      <span>
        <% if reward.challenge %>
          <%= reward.challenge.progress %> / <%= reward.challenge.duration_days %> dias
        <% else %>
          <%= reward.quest.progress %> / <%= reward.quest.total %> desafios
        <% end %>
      </span>
    </div>
    <div class="reward-track">
      <div class="reward-fill locked" style="width: <%= source.progress_percentage %>%"></div>
    </div>
  <% end %>
<% end %>
