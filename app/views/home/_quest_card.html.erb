<div class="quest-card">
  <%= link_to quest_path(quest), style: "text-decoration: none; display: block;" do %>
    <div class="quest-card-header">
      <div style="display: flex; align-items: center;">
        <span class="quest-icon">📖</span>
        <span class="quest-title"><%= quest.title %></span>
      </div>
      <span class="quest-badge"><%= quest.progress %>/<%= quest.total %></span>
    </div>
  <% end %>

  <% actives = quest.active_challenges %>
  <% if actives.any? %>
    <% actives.each do |challenge| %>
      <%= render "home/quest_challenge", challenge: challenge, checked_today: today_checkins.include?(challenge.id) %>
    <% end %>
  <% elsif quest.total == 0 %>
    <p class="quest-sub">Crie seu primeiro desafio para começar</p>
  <% else %>
    <p class="quest-sub">Nenhum desafio em andamento — faça check-in em um planejado para começar</p>
  <% end %>

  <% if quest.total > 0 %>
    <div class="quest-progress-row">
      <span>Progresso</span>
      <span><%= quest.progress %> / <%= quest.total %> desafios</span>
    </div>
    <div class="quest-track">
      <div class="quest-fill" style="width: <%= quest.progress_percentage %>%"></div>
    </div>
  <% end %>
</div>
