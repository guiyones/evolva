<div class="forge-home">
  <%= render "hero",
        streak: @streak,
        solo_count: @solo_count,
        shared_count: @shared_count,
        active_count: @active_count,
        unlocked_count: @unlocked_count %>

  <%= render "day_progress", percentage: @day_progress %>

  <%= render "today",
        challenges: @today_challenges,
        today_pending: @today_pending,
        today_done: @today_done,
        today_checkins: @today_checkins %>

  <div class="section">
    <div class="section-header">
      <span class="section-label">Jornadas</span>
      <%= link_to "+ Nova", new_quest_path, class: "section-action" %>
    </div>

    <% if @active_quests.any? %>
      <% @active_quests.each do |quest| %>
        <%= render "quest_card", quest: quest, today_checkins: @today_checkins %>
      <% end %>
    <% else %>
      <div class="empty">
        <p class="empty-text">Nenhuma jornada ativa.</p>
        <%= link_to "Criar jornada →", new_quest_path, class: "empty-link" %>
      </div>
    <% end %>
  </div>

  <div class="section">
    <div class="section-header">
      <span class="section-label">Desafios</span>
      <%= link_to "+ Novo", new_challenge_path, class: "section-action" %>
    </div>

    <% if @active_challenges.any? %>
      <% @active_challenges.each do |challenge| %>
        <%= render "challenge_card", challenge: challenge, checked_today: @today_checkins.include?(challenge.id) %>
      <% end %>
    <% else %>
      <div class="empty">
        <p class="empty-text">Nenhum desafio independente.</p>
        <%= link_to "Criar desafio →", new_challenge_path, class: "empty-link" %>
      </div>
    <% end %>
  </div>

  <div class="section">
    <div class="section-header">
      <span class="section-label">Recompensas</span>
    </div>

    <% if @rewards.any? %>
      <%= render partial: "reward_card", collection: @rewards, as: :reward %>
    <% else %>
      <div class="empty">
        <p class="empty-text">Nenhuma recompensa ainda.</p>
        <p style="font-size: 11px; color: var(--evolva-border);">Crie um desafio com recompensa.</p>
      </div>
    <% end %>
  </div>
</div>
