<style>
  * { box-sizing: border-box; }
  .forge-home { max-width: 480px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }

  /* Hero */
  .hero { margin-bottom: 1.5rem; }
  .hero-name { font-size: 28px; font-weight: 700; color: #f9fafb; margin-bottom: 4px; }
  .hero-tagline { font-size: 13px; color: #6b7280; margin-bottom: 1rem; }
  .hero-stats { display: flex; gap: 8px; flex-wrap: wrap; }
  .stat-pill { display: flex; align-items: center; gap: 6px; padding: 6px 12px;
               border-radius: 40px; border: 0.5px solid #1f2937;
               background: #111827; font-size: 12px; font-weight: 500; }
  .stat-pill.streak { border-color: rgba(251,146,60,0.3); color: #fb923c; }
  .stat-pill.challenges { border-color: rgba(99,102,241,0.3); color: #818cf8; }
  .stat-pill.rewards { border-color: rgba(16,185,129,0.3); color: #34d399; }

  /* Day progress */
  .day-progress-card { background: #111827; border: 0.5px solid #1f2937;
                       border-radius: 14px; padding: 14px 16px; margin-bottom: 1.5rem; }
  .day-progress-header { display: flex; justify-content: space-between;
                         align-items: center; margin-bottom: 10px; }
  .day-progress-label { font-size: 13px; font-weight: 500; color: #f3f4f6; }
  .day-progress-pct { font-size: 13px; font-weight: 600;
                      color: <%= @day_progress == 100 ? '#34d399' : '#818cf8' %>; }
  .day-progress-track { height: 4px; background: #1f2937; border-radius: 4px; overflow: hidden; }
  .day-progress-fill { height: 100%; border-radius: 4px;
                       background: <%= @day_progress == 100 ? 'linear-gradient(90deg, #10b981, #34d399)' : 'linear-gradient(90deg, #6366f1, #818cf8)' %>;
                       transition: width 0.3s; }

  /* Section */
  .section { margin-bottom: 1.5rem; }
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .section-label { font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
                   text-transform: uppercase; color: #6b7280; }
  .section-action { font-size: 12px; color: #818cf8; text-decoration: none; }
  .section-action:hover { color: #a5b4fc; }

  /* Hoje card */
  .hoje-card { background: #111827; border: 0.5px solid #1f2937; border-radius: 12px;
               padding: 12px 14px; display: flex; align-items: center;
               justify-content: space-between; gap: 12px; margin-bottom: 6px;
               transition: border-color 0.2s; }
  .hoje-card:hover { border-color: #374151; }
  .hoje-card.done { opacity: 0.5; }
  .hoje-card-left { flex: 1; min-width: 0; }
  .hoje-card-title { font-size: 14px; font-weight: 500; color: #f3f4f6;
                     display: flex; align-items: center; gap: 6px; }
  .hoje-card-meta { font-size: 11px; color: #6b7280; margin-top: 3px; }
  .hoje-card-meta span { color: #818cf8; }
  .hoje-checkin-btn { flex-shrink: 0; padding: 5px 14px; border-radius: 8px;
                      background: #059669; color: #fff; font-size: 11px; font-weight: 500;
                      text-decoration: none; white-space: nowrap; transition: background 0.15s; }
  .hoje-checkin-btn:hover { background: #047857; }
  .hoje-done-badge { flex-shrink: 0; font-size: 11px; color: #374151; }

  /* Quest card */
  .quest-card { background: #0f172a; border: 0.5px solid #1e3a5f; border-radius: 14px;
                padding: 14px 16px; text-decoration: none; display: block;
                transition: border-color 0.2s, transform 0.15s; margin-bottom: 8px;
                box-shadow: 0 4px 24px rgba(99,102,241,0.06); }
  .quest-card:hover { border-color: #3b82f6; transform: translateY(-1px); }
  .quest-card-header { display: flex; align-items: flex-start;
                       justify-content: space-between; gap: 8px; margin-bottom: 6px; }
  .quest-icon { font-size: 18px; margin-right: 8px; }
  .quest-title { font-size: 15px; font-weight: 600; color: #f3f4f6; line-height: 1.3; }
  .quest-badge { font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 20px;
                 white-space: nowrap; flex-shrink: 0;
                 background: rgba(16,185,129,0.15); color: #34d399; }
  .quest-sub { font-size: 12px; color: #6b7280; margin-bottom: 10px; line-height: 1.5; }
  .quest-sub span { color: #9ca3af; }
  .quest-progress-row { display: flex; justify-content: space-between;
                        font-size: 11px; color: #6b7280; margin-bottom: 5px; }
  .quest-track { height: 3px; background: #1e3a5f; border-radius: 3px; overflow: hidden; }
  .quest-fill { height: 100%; border-radius: 3px;
                background: linear-gradient(90deg, #10b981, #34d399); }

  /* Challenge card */
  .challenge-card { background: #111827; border: 0.5px solid #1f2937; border-radius: 12px;
                    padding: 12px 14px; margin-bottom: 8px;
                    transition: border-color 0.2s, transform 0.15s; }
  .challenge-card:hover { border-color: #374151; transform: translateY(-1px); }
  .challenge-card-link { text-decoration: none; display: block; }
  .challenge-card-header { display: flex; align-items: flex-start;
                           justify-content: space-between; gap: 8px; margin-bottom: 4px; }
  .challenge-title { font-size: 14px; font-weight: 500; color: #f3f4f6; line-height: 1.3; }
  .challenge-badge { font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 20px;
                     white-space: nowrap; flex-shrink: 0;
                     background: rgba(99,102,241,0.15); color: #818cf8; }
  .challenge-meta { font-size: 11px; color: #4b5563; margin-bottom: 8px; }
  .challenge-progress-row { display: flex; justify-content: space-between;
                             font-size: 11px; color: #6b7280; margin-bottom: 5px; }
  .challenge-track { height: 2px; background: #1f2937; border-radius: 2px;
                     overflow: hidden; margin-bottom: 8px; }
  .challenge-fill { height: 100%; border-radius: 2px; background: #6366f1; }
  .challenge-checkin { font-size: 11px; color: #4b5563; }
  .challenge-checkin-link { font-size: 11px; color: #818cf8; text-decoration: none; }
  .challenge-checkin-link:hover { color: #a5b4fc; }

  /* Reward card */
  .reward-card { border-radius: 12px; padding: 12px 14px; text-decoration: none;
                 display: block; margin-bottom: 8px;
                 transition: border-color 0.2s, transform 0.15s; }
  .reward-card:hover { transform: translateY(-1px); }
  .reward-card.unlocked { background: #0a1f14; border: 0.5px solid rgba(16,185,129,0.3); }
  .reward-card.locked { background: #111827; border: 0.5px solid #1f2937; }
  .reward-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .reward-icon { width: 32px; height: 32px; border-radius: 8px; display: flex;
                 align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
  .reward-icon.unlocked { background: rgba(16,185,129,0.2); }
  .reward-icon.locked { background: #1f2937; }
  .reward-info { flex: 1; min-width: 0; }
  .reward-title { font-size: 13px; font-weight: 500; color: #f3f4f6; }
  .reward-title.locked { color: #9ca3af; }
  .reward-source { font-size: 11px; color: #6b7280; margin-top: 2px; }
  .reward-divider { height: 0.5px; background: rgba(16,185,129,0.15); margin: 6px 0; }
  .reward-status { font-size: 11px; font-weight: 500; color: #34d399; }
  .reward-progress-row { display: flex; justify-content: space-between;
                         font-size: 11px; color: #6b7280; margin-bottom: 5px; margin-top: 6px; }
  .reward-track { height: 2px; background: #1f2937; border-radius: 2px; overflow: hidden; }
  .reward-fill { height: 100%; border-radius: 2px; }
  .reward-fill.locked { background: #374151; }

  /* Empty */
  .empty { text-align: center; padding: 24px 0; }
  .empty-text { font-size: 13px; color: #4b5563; margin-bottom: 8px; }
  .empty-link { font-size: 12px; color: #818cf8; text-decoration: none; }
  .empty-link:hover { color: #a5b4fc; }
</style>

<div class="forge-home">

  <%# Hero %>
  <div class="hero">
    <% display_name = Current.user.name.present? ? Current.user.name : Current.user.email_address.split("@").first %>
    <p class="hero-name"><%= display_name.capitalize %></p>
    <p class="hero-tagline">Pequenos progressos criam grandes mudanças.</p>
    <div class="hero-stats">
      <div class="stat-pill streak">
        <span>🔥</span>
        <span><%= @streak %> <%= @streak == 1 ? "dia seguido" : "dias seguidos" %></span>
      </div>
      <div class="stat-pill challenges">
        <span>⚔️</span>
        <span><%= @active_count %> <%= @active_count == 1 ? "desafio ativo" : "desafios ativos" %></span>
      </div>
      <div class="stat-pill rewards">
        <span>🏆</span>
        <span><%= @unlocked_count %> <%= @unlocked_count == 1 ? "recompensa" : "recompensas" %></span>
      </div>
    </div>
  </div>

  <%# Progresso do dia %>
  <div class="day-progress-card">
    <div class="day-progress-header">
      <span class="day-progress-label">Progresso do dia</span>
      <span class="day-progress-pct"><%= @day_progress %>%</span>
    </div>
    <div class="day-progress-track">
      <div class="day-progress-fill" style="width: <%= @day_progress %>%"></div>
    </div>
  </div>

  <%# Hoje %>
  <div class="section">
    <div class="section-header">
      <span class="section-label">Hoje</span>
      <% pendentes = @today_challenges.reject { |c| @today_checkins.include?(c.id) } %>
      <% if pendentes.empty? && @today_challenges.any? %>
        <span style="font-size: 12px; color: #34d399;">✓ Dia completo</span>
      <% elsif pendentes.any? %>
        <span style="font-size: 12px; color: #6b7280;"><%= pendentes.count %> pendente<%= pendentes.count == 1 ? "" : "s" %></span>
      <% end %>
    </div>

    <% if @today_challenges.empty? %>
      <div class="empty">
        <p class="empty-text">Nenhum desafio ativo hoje.</p>
      </div>
    <% else %>
      <% @today_challenges.each do |challenge| %>
        <% done = @today_checkins.include?(challenge.id) %>
        <div class="hoje-card <%= done ? 'done' : '' %>">
          <div class="hoje-card-left">
            <p class="hoje-card-title">
              <%= done ? "✓" : "◦" %> <%= challenge.title %>
            </p>
            <p class="hoje-card-meta">
              <% if challenge.quest.present? %>
                Jornada: <span><%= challenge.quest.title %></span> ·
              <% else %>
                Desafio pessoal ·
              <% end %>
              <%= challenge.progress %> / <%= challenge.duration_days %> dias
            </p>
          </div>
          <% if done %>
            <span class="hoje-done-badge">✓ feito</span>
          <% else %>
            <%= link_to "✔ Check-in", new_challenge_checkin_path(challenge), class: "hoje-checkin-btn" %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Jornadas %>
  <div class="section">
    <div class="section-header">
      <span class="section-label">Jornadas</span>
      <%= link_to "+ Nova", new_quest_path, class: "section-action" %>
    </div>

    <% if @active_quests.any? %>
      <% @active_quests.each do |quest| %>
        <%= link_to quest_path(quest), class: "quest-card" do %>
          <div class="quest-card-header">
            <div style="display: flex; align-items: center;">
              <span class="quest-icon">📖</span>
              <span class="quest-title"><%= quest.title %></span>
            </div>
            <span class="quest-badge"><%= quest.progress %>/<%= quest.total %></span>
          </div>
          <% current = quest.current_challenge %>
          <% if current %>
            <p class="quest-sub">Agora: <span><%= current.title %></span> · <%= current.progress %>/<%= current.duration_days %> dias</p>
          <% elsif quest.next_challenge_available? %>
            <p class="quest-sub" style="color: #818cf8;">Pronto para o próximo desafio</p>
          <% elsif quest.total == 0 %>
            <p class="quest-sub">Crie seu primeiro desafio para começar</p>
          <% else %>
            <p class="quest-sub">Nenhum desafio ativo</p>
          <% end %>
          <% if quest.total > 0 %>
            <div class="quest-progress-row">
              <span>Progresso</span>
              <span><%= quest.progress %> / <%= quest.total %> desafios</span>
            </div>
            <div class="quest-track">
              <div class="quest-fill" style="width: <%= quest.progress_percentage %>%"></div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% else %>
      <div class="empty">
        <p class="empty-text">Nenhuma jornada ativa.</p>
        <%= link_to "Criar jornada →", new_quest_path, class: "empty-link" %>
      </div>
    <% end %>
  </div>

  <%# Desafios independentes %>
  <div class="section">
    <div class="section-header">
      <span class="section-label">Desafios</span>
      <%= link_to "+ Novo", new_challenge_path, class: "section-action" %>
    </div>

    <% if @active_challenges.any? %>
      <% @active_challenges.each do |challenge| %>
        <% checked_today = @today_checkins.include?(challenge.id) %>
        <div class="challenge-card">
          <%= link_to challenge_path(challenge), class: "challenge-card-link" do %>
            <div class="challenge-card-header">
              <span class="challenge-title"><%= challenge.title %></span>
              <span class="challenge-badge"><%= challenge.progress %> / <%= challenge.duration_days %></span>
            </div>
            <p class="challenge-meta">Desafio pessoal</p>
            <div class="challenge-progress-row">
              <span><%= challenge.progress %> / <%= challenge.duration_days %> dias</span>
              <span><%= challenge.progress_percentage %>%</span>
            </div>
            <div class="challenge-track">
              <div class="challenge-fill" style="width: <%= challenge.progress_percentage %>%"></div>
            </div>
          <% end %>
          <% if checked_today %>
            <span class="challenge-checkin">✓ feito hoje</span>
          <% else %>
            <%= link_to "Check-in de hoje →", new_challenge_checkin_path(challenge), class: "challenge-checkin-link" %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="empty">
        <p class="empty-text">Nenhum desafio independente.</p>
        <%= link_to "Criar desafio →", new_challenge_path, class: "empty-link" %>
      </div>
    <% end %>
  </div>

  <%# Recompensas %>
  <div class="section">
    <div class="section-header">
      <span class="section-label">Recompensas</span>
    </div>

    <% all_rewards = @unlocked_rewards.to_a + @locked_rewards.to_a %>
    <% if all_rewards.any? %>
      <% @unlocked_rewards.each do |reward| %>
        <%= link_to reward_path(reward), class: "reward-card unlocked" do %>
          <div class="reward-row">
            <div class="reward-icon unlocked">🎁</div>
            <div class="reward-info">
              <p class="reward-title"><%= reward.description %></p>
              <p class="reward-source"><%= reward.challenge&.title || reward.quest&.title %></p>
            </div>
          </div>
          <div class="reward-divider"></div>
          <span class="reward-status">Pronto para resgatar</span>
        <% end %>
      <% end %>
      <% @locked_rewards.each do |reward| %>
        <% source = reward.challenge || reward.quest %>
        <%= link_to reward_path(reward), class: "reward-card locked" do %>
          <div class="reward-row">
            <div class="reward-icon locked">🔒</div>
            <div class="reward-info">
              <p class="reward-title locked"><%= reward.description %></p>
              <p class="reward-source"><%= source&.title %></p>
            </div>
          </div>
          <% if source %>
            <div class="reward-progress-row">
              <span>Progresso</span>
              <span>
                <% if reward.challenge %>
                  <%= reward.challenge.progress %> / <%= reward.challenge.duration_days %> dias
                <% else %>
                  <%= reward.quest.progress %> / <%= reward.quest.total %> desafios
                <% end %>
              </span>
            </div>
            <div class="reward-track">
              <div class="reward-fill locked" style="width: <%= source.progress_percentage %>%"></div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% else %>
      <div class="empty">
        <p class="empty-text">Nenhuma recompensa ainda.</p>
        <p style="font-size: 11px; color: #374151;">Crie um desafio com recompensa.</p>
      </div>
    <% end %>
  </div>

</div>

