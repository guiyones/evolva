<div class="challenge-card">
  <%= link_to challenge_path(challenge), class: "challenge-card-link" do %>
    <div class="challenge-card-header">
      <span class="challenge-title"><%= challenge.title %></span>
      <span class="challenge-badge"><%= challenge.progress %> / <%= challenge.duration_days %></span>
    </div>
    <p class="challenge-meta">Desafio pessoal</p>
    <div class="challenge-progress-row">
      <span><%= challenge.progress %> / <%= challenge.duration_days %> dias</span>
      <span><%= challenge.progress_percentage %>%</span>
    </div>
    <div class="challenge-track">
      <div class="challenge-fill" style="width: <%= challenge.progress_percentage %>%"></div>
    </div>
  <% end %>
  <% if checked_today %>
    <span class="challenge-checkin">✓ feito hoje</span>
  <% else %>
    <%= link_to "Check-in de hoje →", new_challenge_checkin_path(challenge), class: "challenge-checkin-link" %>
  <% end %>
</div>
