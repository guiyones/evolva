<!DOCTYPE html>
<html>
  <head>
    <title>Evolva</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0f172a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Evolva">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <%= tag.link rel: "apple-touch-icon", href: "/icon-192.png" %>
    <%= tag.link rel: "icon", type: "image/png", href: "/icon-192.png" %>
    <%= stylesheet_link_tag "application", "nav", "home", "cards", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/service-worker.js', { scope: '/' })
      }
    </script>
  </head>
  <body class="bg-gray-950 text-white min-h-screen">
    <% if authenticated? %>
      <%= render "shared/desktop_nav" %>
    <% end %>

    <%= render "shared/flash" %>

    <%= yield %>

    <% if authenticated? %>
      <%= render "shared/bottom_nav" %>
    <% end %>
  </body>
</html>
