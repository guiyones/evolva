<div class="reward-show">
  <%= link_to "← Voltar", challenge_path(@reward.challenge), class: "reward-back" %>

  <% if @reward.locked? %>
    <div class="reward-state">
      <div class="reward-state-icon">🔒</div>
      <h1><%= @reward.description %></h1>
      <p class="muted">Complete o desafio para desbloquear.</p>

      <div class="source">
        <div class="source-row">
          <span><%= @reward.challenge.title %></span>
          <span><%= @reward.challenge.progress %> de <%= @reward.challenge.duration_days %> dias</span>
        </div>
        <div class="source-track">
          <div class="source-fill" style="width: <%= @reward.challenge.progress_percentage %>%"></div>
        </div>
      </div>
    </div>

  <% elsif @reward.unlocked? %>
    <div class="reward-state">
      <div class="reward-state-icon">🎁</div>
      <p class="reward-state-label unlocked">Recompensa desbloqueada</p>
      <h1><%= @reward.description %></h1>
      <p>
        Você completou <strong style="color: var(--evolva-text);"><%= @reward.challenge.title %></strong>.<br>
        Você fez exatamente o que prometeu.
      </p>

      <%= button_to "Marcar como resgatado", redeem_reward_path(@reward),
          method: :patch,
          class: "reward-redeem-btn" %>
    </div>

  <% elsif @reward.redeemed? %>
    <div class="reward-state">
      <div class="reward-state-icon">✅</div>
      <p class="reward-state-label redeemed">Resgatado</p>
      <h1><%= @reward.description %></h1>
      <p class="muted">Resgatado em <%= @reward.completed_at.strftime("%d/%m/%Y") %></p>
    </div>
  <% end %>
</div>
